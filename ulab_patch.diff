+        unsigned long long k = 1UL << i;
+        unsigned long long s = 1;
+        mp_float_t sum = ULAB_ZERO;
+        mp_float_t *Rt;
+        h /= ULAB_TWO;
+        for (j = 1; j < k; j += 2)
