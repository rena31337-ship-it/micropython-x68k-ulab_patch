+static mp_float_t vector_sinc1(mp_float_t x) {
+    if (x == MICROPY_FLOAT_CONST(0.)) {
+        return MICROPY_FLOAT_CONST(1.);
+    }
+    x *= MP_PI;
+    return MICROPY_FLOAT_C_FUN(sin)(x) / x;
+}
