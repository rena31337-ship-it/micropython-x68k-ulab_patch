+// X68000 ńēł reshape Õ«¤ĶŻģ’╝łĶ╗ĮķćÅŃā╗denseÕ░éńö© + -1Õ»ŠÕ┐£ + inplaceÕ»ŠÕ┐£’╝ē
+mp_obj_t ndarray_reshape_core(mp_obj_t self_in, mp_obj_t shape_in, bool allow_copy) {
+    ndarray_obj_t *self = MP_OBJ_TO_PTR(self_in);
+
+    if (!mp_obj_is_type(shape_in, &mp_type_tuple)) {
+        mp_raise_TypeError(MP_ERROR_TEXT("shape must be a tuple"));
+    }
+
+    mp_obj_tuple_t *shape_tuple = MP_OBJ_TO_PTR(shape_in);
+    size_t new_ndim = shape_tuple->len;
+
+    if (new_ndim > ULAB_MAX_DIMS || new_ndim == 0) {  // 0Ńü»õĖĆÕ┐£Õ╝ŠŃüÅ’╝łulabŃü«ndimµ£ĆÕ░Å1µā│Õ«Ü’╝ē
+        mp_raise_ValueError(MP_ERROR_TEXT("invalid number of dimensions"));
+    }
+
+    // µ¢░ŃüŚŃüä shape’╝łÕŠīŃéŹĶ®░Ńéü’╝ē
+    size_t *new_shape = m_new(size_t, ULAB_MAX_DIMS);
+    memset(new_shape, 0, sizeof(size_t) * ULAB_MAX_DIMS);
+
+    int neg_one_pos = -1;          // -1ŃüīŃüéŃüŻŃü¤ńøĖÕ»ŠõĮŹńĮ«
+    size_t known_product = 1;
+
+    for (size_t i = 0; i < new_ndim; i++) {
+        mp_int_t dim_val = mp_obj_get_int(shape_tuple->items[i]);
+        size_t pos = ULAB_MAX_DIMS - new_ndim + i;
+
+        if (dim_val == -1) {
+            if (neg_one_pos != -1) {
+                mp_raise_ValueError(MP_ERROR_TEXT("can only use -1 once"));
+            }
+            neg_one_pos = i;
+            new_shape[pos] = 0;  // ÕŠīŃü¦Õ¤ŗŃéüŃéŗ
+        } else if (dim_val < 0) {
+            mp_raise_ValueError(MP_ERROR_TEXT("negative dimensions not allowed except -1"));
+        } else {
+            new_shape[pos] = (size_t)dim_val;
+            if (known_product > SIZE_MAX / new_shape[pos]) {
+                mp_raise_ValueError(MP_ERROR_TEXT("array is too big"));
+            }
+            known_product *= new_shape[pos];
+        }
+    }
+
+    // ŃéĄŃéżŃé║Ķ©łń«Ś’╝ł-1ŃüéŃéŖ/Ńü¬ŃüŚŃü¦ÕłåÕ▓É’╝ē
+    size_t new_len = self->len;
+    if (neg_one_pos != -1) {
+        if (known_product == 0 || self->len % known_product != 0) {
+            mp_raise_ValueError(MP_ERROR_TEXT("incompatible shape"));
+        }
+        size_t missing_dim = self->len / known_product;
+        new_shape[ULAB_MAX_DIMS - new_ndim + neg_one_pos] = missing_dim;
+    } else {
+        size_t calc_len = 1;
+        for (size_t i = ULAB_MAX_DIMS - new_ndim; i < ULAB_MAX_DIMS; i++) {
+            if (calc_len > SIZE_MAX / new_shape[i]) {
+                mp_raise_ValueError(MP_ERROR_TEXT("array is too big"));
+            }
+            calc_len *= new_shape[i];
+        }
+        if (calc_len != self->len) {
+            mp_raise_ValueError(MP_ERROR_TEXT("incompatible shape"));
+        }
+    }
+
+    // stridesÕåŹĶ©łń«Ś’╝łC-order’╝ē
+    int32_t *new_strides = m_new(int32_t, ULAB_MAX_DIMS);
+    memset(new_strides, 0, sizeof(int32_t) * ULAB_MAX_DIMS);  // ÕēŹÕŹŖŃéÆ0Ńé»Ńā¬Ńéó
+    size_t stride = self->itemsize;
+    for (int i = (int)ULAB_MAX_DIMS - 1; i >= (int)(ULAB_MAX_DIMS - new_ndim); i--) {
+        new_strides[i] = (int32_t)stride;
+        stride *= new_shape[i];
+    }
+
+    // ===== ŃüōŃüōŃüŗŃéēµ£¼ńĢ¬ =====
+    if (allow_copy) {
+        // a.shape = (3, -1) ŌåÆ ÕģāŃé¬Ńā¢ŃéĖŃé¦Ńé»ŃāłŃéÆńø┤µÄźµøĖŃüŹµÅøŃüł’╝łinplace’╝ē
+        self->ndim = (uint8_t)new_ndim;
+        memcpy(self->shape, new_shape, sizeof(size_t) * ULAB_MAX_DIMS);
+        memcpy(self->strides, new_strides, sizeof(int32_t) * ULAB_MAX_DIMS);
+        m_del(size_t, new_shape, ULAB_MAX_DIMS);
+        m_del(int32_t, new_strides, ULAB_MAX_DIMS);
+        return self_in;
+    } else {
+        // a.reshape((3, -1)) ŌåÆ µ¢░ŃüŚŃüäviewŃéÆĶ┐öŃüÖ’╝łŃé╝ŃāŁŃé│ŃāöŃā╝’╝ē
+        ndarray_obj_t *out = m_new_obj(ndarray_obj_t);
+        *out = *self;
+        out->ndim = (uint8_t)new_ndim;
+        out->len = new_len;
+        memcpy(out->shape, new_shape, sizeof(size_t) * ULAB_MAX_DIMS);
+        memcpy(out->strides, new_strides, sizeof(int32_t) * ULAB_MAX_DIMS);
+
+        m_del(size_t, new_shape, ULAB_MAX_DIMS);
+        m_del(int32_t, new_strides, ULAB_MAX_DIMS);
+        return MP_OBJ_FROM_PTR(out);
+    }
+}
