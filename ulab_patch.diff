+    }
+
+    // Õć║ÕŖø shape = (m, n)
+    size_t out_shape[ULAB_MAX_DIMS] = {0};
+    out_shape[ULAB_MAX_DIMS - 2] = m;
+    out_shape[ULAB_MAX_DIMS - 1] = n;
+
+    ndarray_obj_t *out = ndarray_new_dense_ndarray(2, out_shape, dtype);
+
+    mp_float_t *A = (mp_float_t *)lhs->array;
+    mp_float_t *B = (mp_float_t *)rhs->array;
+    mp_float_t *C = (mp_float_t *)out->array;
+
+    int32_t As0 = lhs->strides[ULAB_MAX_DIMS - 2] / (int32_t)lhs->itemsize;
+    int32_t As1 = lhs->strides[ULAB_MAX_DIMS - 1] / (int32_t)lhs->itemsize;
+    int32_t Bs0 = rhs->strides[ULAB_MAX_DIMS - 2] / (int32_t)rhs->itemsize;
+    int32_t Bs1 = rhs->strides[ULAB_MAX_DIMS - 1] / (int32_t)rhs->itemsize;
+    int32_t Cs0 = out->strides[ULAB_MAX_DIMS - 2] / (int32_t)out->itemsize;
+    int32_t Cs1 = out->strides[ULAB_MAX_DIMS - 1] / (int32_t)out->itemsize;
+
+    for (size_t i = 0; i < m; i++) {
+        for (size_t j = 0; j < n; j++) {
+            mp_float_t acc = 0;
+            for (size_t t = 0; t < k1; t++) {
+                mp_float_t a = A[i * As0 + t * As1];
+                mp_float_t b = B[t * Bs0 + j * Bs1];
+                acc += a * b;
+            }
+            C[i * Cs0 + j * Cs1] = acc;
+        }
+    }
+
+    return MP_OBJ_FROM_PTR(out);
+}
