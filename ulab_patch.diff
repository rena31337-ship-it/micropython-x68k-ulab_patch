+test_function('log', 1.0, np.log(2.718281828459045))
+
+test_function('log2', 1.0, np.log2(2))
+
+test_function('log10', 1.0, np.log10(10.0))
+
+test_function('expm1', 1.0, np.exp(1) - np.expm1(1))
