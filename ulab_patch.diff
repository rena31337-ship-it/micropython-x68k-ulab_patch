+#if NDARRAY_HAS_FLATTEN
+
+mp_obj_t ndarray_flatten(size_t n_args, const mp_obj_t *pos_args, mp_map_t *kw_args) {
+    static const mp_arg_t allowed_args[] = {
+        { MP_QSTR_order, MP_ARG_KW_ONLY | MP_ARG_OBJ, {.u_rom_obj = MP_ROM_QSTR(MP_QSTR_C)} },
+    };
+    mp_arg_val_t args[MP_ARRAY_SIZE(allowed_args)];
+    mp_arg_parse_all(n_args - 1, pos_args + 1, kw_args,
+        MP_ARRAY_SIZE(allowed_args), allowed_args, args);
+
+    ndarray_obj_t *self = MP_OBJ_TO_PTR(pos_args[0]);
+
+    GET_STR_DATA_LEN(args[0].u_obj, order, len);
+    if (len != 1 || (order[0] != 'C' && order[0] != 'F')) {
+        mp_raise_ValueError(MP_ERROR_TEXT("order must be 'C' or 'F'"));
+    }
+
+    ndarray_obj_t *out = ndarray_new_linear_array(self->len, self->dtype);
+    uint8_t *dst = (uint8_t *)out->array;
+
+    // -------------------------
+    // C-order
+    // -------------------------
+    if (order[0] == 'C') {
+        if (ndarray_is_dense(self)) {
+            memcpy(dst, self->array, self->len * self->itemsize);
+        } else {
+            uint8_t *src = (uint8_t *)self->array;
+            ITERATOR_HEAD();
+                memcpy(dst, src, self->itemsize);
+                dst += out->itemsize;
+            ITERATOR_TAIL(self, src);
+        }
+    }
+
+        // -------------------------
+        // F-order
+        // -------------------------
+        else {
+            size_t ndim = self->ndim;
+            size_t shape[ULAB_MAX_DIMS];
+            int32_t strides[ULAB_MAX_DIMS];   // ŌåÉ int32_tŃü«ŃüŠŃüŠ
+            size_t indices[ULAB_MAX_DIMS];
+
+            // µŁŻŃüŚŃüäõĮŹńĮ«ŃüŗŃéēŃé│ŃāöŃā╝’╝łulabŃü«ÕŠīŃéŹĶ®░ŃéüÕ»ŠÕ┐£’╝ē
+            for (size_t i = 0; i < ndim; i++) {
+                shape[i]   = self->shape[ULAB_MAX_DIMS - ndim + i];
+                strides[i] = self->strides[ULAB_MAX_DIMS - ndim + i];
+                indices[i] = 0;
+            }
+
+            uint8_t *src = (uint8_t *)self->array;
+
+            while (true) {
+                memcpy(dst, src, self->itemsize);
+                dst += out->itemsize;
+
+                int dim = 0;
+                while (dim < (int)ndim) {
+                    indices[dim]++;
+                    src += strides[dim];
+
+                    if (indices[dim] < shape[dim]) {
+                        break;
+                    }
+
+                    src -= strides[dim] * indices[dim];
+                    indices[dim] = 0;
+                    dim++;
+                }
+                if (dim == (int)ndim) {
+                    break;
+                }
+            }
+        }
+    return MP_OBJ_FROM_PTR(out);
+}
+
+MP_DEFINE_CONST_FUN_OBJ_KW(ndarray_flatten_obj, 1, ndarray_flatten);
+
+#endif /* NDARRAY_HAS_FLATTEN */
+
+#if NDARRAY_HAS_REPEAT
+// µ£ĆÕ░ÅķÖÉńēł repeat (axis=None Ńü«Ńü┐Ńā╗floatÕ»ŠÕ┐£)
+mp_obj_t ndarray_repeat(mp_obj_t self_in, mp_obj_t repeats_in) {
+    ndarray_obj_t *self = MP_OBJ_TO_PTR(self_in);
+
+    size_t total_repeats = 0;
+    bool repeats_is_array = false;
+    size_t *repeats = NULL;
+
+    // repeats ŃüīŃé╣Ńé½Ńā®Ńā╝’╝łint or float’╝ē
+    if (mp_obj_is_int(repeats_in) || mp_obj_is_float(repeats_in)) {
+        mp_float_t r_float = mp_obj_get_float(repeats_in);
+        if (r_float < 0) {
+            mp_raise_ValueError(MP_ERROR_TEXT("negative repeat count"));
+        }
+        mp_int_t r = (mp_int_t)r_float;
+        total_repeats = (size_t)r * self->len;
+    }
+    // repeats ŃüīķģŹÕłŚ’╝łÕÉäĶ”üń┤ĀŃüöŃü©Ńü½Õø×µĢ░µīćÕ«Ü’╝ē
+    else {
+        ndarray_obj_t *r_array = ndarray_from_mp_obj(repeats_in, 0);
+        if (r_array->len != self->len) {
+            mp_raise_ValueError(MP_ERROR_TEXT("repeats must be same length as array"));
+        }
+        repeats_is_array = true;
+        repeats = m_new(size_t, self->len);
+        for (size_t i = 0; i < self->len; i++) {
+            mp_float_t val = mp_obj_get_float(mp_binary_get_val_array(r_array->dtype, r_array->array, i));
+            if (val < 0) {
+                mp_raise_ValueError(MP_ERROR_TEXT("negative repeat count"));
+            }
+            repeats[i] = (size_t)val;
+            total_repeats += repeats[i];
+        }
+    }
+
+    if (total_repeats == 0) {
+        return MP_OBJ_FROM_PTR(ndarray_new_linear_array(0, self->dtype));
+    }
+
+    ndarray_obj_t *out = ndarray_new_linear_array(total_repeats, self->dtype);
+    uint8_t *dst = (uint8_t *)out->array;
+    uint8_t *src = (uint8_t *)self->array;
+
+    if (!repeats_is_array) {
+        mp_float_t r_float = mp_obj_get_float(repeats_in);
+        mp_int_t r = (mp_int_t)r_float;
+        for (size_t i = 0; i < self->len; i++) {
+            for (mp_int_t k = 0; k < r; k++) {
+                memcpy(dst, src, self->itemsize);
+                dst += self->itemsize;
+            }
+            src += self->itemsize;
+        }
+    } else {
+        for (size_t i = 0; i < self->len; i++) {
+            for (size_t k = 0; k < repeats[i]; k++) {
+                memcpy(dst, src, self->itemsize);
+                dst += self->itemsize;
+            }
+            src += self->itemsize;
+        }
+        m_del(size_t, repeats, self->len);
+    }
+
+    return MP_OBJ_FROM_PTR(out);
+}
+
+MP_DEFINE_CONST_FUN_OBJ_2(ndarray_repeat_obj, ndarray_repeat);
+#endif /* NDARRAY_HAS_REPEAT */
